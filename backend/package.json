{
  "name": "@orbi/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint src/",
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsx watch src/server.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed:dev": "tsx src/db/seed-dev.ts",
    "db:reset": "tsx src/db/reset.ts",
    "db:reset:dev": "pnpm db:reset && pnpm db:seed:dev"
  },
  "dependencies": {
    "@orbi/shared": "workspace:*",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "kysely": "^0.28.11",
    "mysql2": "^3.19.0",
    "nanoid": "^5.1.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^3.0.9"
  }
}
